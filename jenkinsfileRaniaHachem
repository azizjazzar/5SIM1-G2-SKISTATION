pipeline {
    agent any

    stages {
        stage('Clean') {
            steps {
                echo 'Starting Clean Stage'
                sh 'mvn clean' 
            }
        }

        stage('Build') {
            steps {
                echo 'Starting Build Stage'
                sh 'mvn compile'
            }
        }

        stage('Confirmation') {
            steps {
                echo 'Pipeline executed successfully!'
            }
        }
    }

    post {
        always {
            echo 'Pipeline has finished running.'
        }
    }
}
